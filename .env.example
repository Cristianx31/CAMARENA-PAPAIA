# Ejemplo de archivo de variables de entorno para el proyecto
# Copia este archivo a .env y reemplaza los valores por los tuyos

# URL de conexión a MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/<nombreBaseDeDatos>?retryWrites=true&w=majority

# URL de conexión local como respaldo (opcional)
MONGODB_LOCAL=mongodb://localhost:27017/PapasDB

# Puerto donde correrá la aplicación
PORT=3000

# Secreto para las sesiones de Express
SESSION_SECRET=tu_clave_secreta_aqui
